# Copie este arquivo para .env e preencha com valores locais.
# Nunca commitar o .env com valores reais.

# PostgreSQL
POSTGRES_DB=visiosys
POSTGRES_USER=your_pg_user
POSTGRES_PASSWORD=your_pg_password

# MongoDB
MONGO_DB=visiosys_audit
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password

# Connection strings para a aplicação
CONNECTIONSTRINGS__POSTGRES=Host=localhost;Port=5432;Database=visiosys;Username=your_pg_user;Password=your_pg_password
CONNECTIONSTRINGS__MONGO=mongodb://your_mongo_user:your_mongo_password@localhost:27017

# Seq
SEQ_URL=http://localhost:5341
