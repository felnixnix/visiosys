{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [{ "Name": "Console" }],
    "Enrich": ["FromLogContext"]
  },
  "ConnectionStrings": {
    "Postgres": "",
    "Mongo": ""
  },
  "Worker": {
    "IntervalMinutos": 30,
    "TribunalBaseUrl": ""
  }
}
