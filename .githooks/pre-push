#!/usr/bin/env bash
#
# pre-push: validacao local rapida antes de cada push (~30s).
# Executa build Release + testes unitarios de dominio.
# Para simulacao completa do CI (act): bash scripts/validate-ci.sh
# Para pular este hook: git push --no-verify
#

set -euo pipefail

log()  { echo "[pre-push] $*"; }
fail() { echo "[pre-push] FALHOU: $*"; exit 1; }

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Build completo em Release — pega erros de compilacao C# e frontend
log "Build Release..."
if ! dotnet build --configuration Release --nologo -v quiet 2>&1; then
  fail "dotnet build falhou. Corrija os erros antes de fazer push."
fi
log "Build OK."

# Testes de dominio (sem Docker, rapido)
log "Testes unitarios de dominio..."
if ! dotnet test tests/Visiosys.Domain.Tests/Visiosys.Domain.Tests.csproj \
    --configuration Release --no-build --nologo \
    --logger "console;verbosity=minimal" 2>&1; then
  fail "Testes de dominio falharam."
fi
log "Testes OK."

# Verificacao TypeScript do frontend
if command -v npm > /dev/null 2>&1 && [ -f "src/Visiosys.Frontend/package.json" ]; then
  log "Verificacao TypeScript do frontend..."
  if ! (cd src/Visiosys.Frontend && npx tsc --noEmit 2>&1); then
    fail "Erro de tipagem TypeScript no frontend. Corrija antes de fazer push."
  fi
  log "TypeScript OK."
fi

log ""
log "Validacao local passou. Prosseguindo com o push."
log "(Para CI completo com Testcontainers: bash scripts/validate-ci.sh)"
